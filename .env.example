# ========================================
# FDC Modular Starter Environment Variables
# ========================================
#
# Copy this file to .env.local and fill in your values.
#
# cp .env.example .env.local
#

# ----------------------------------------
# Supabase
# ----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------
# Google OAuth
# ----------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ----------------------------------------
# Token Encryption
# ----------------------------------------
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key

# ----------------------------------------
# App Settings
# ----------------------------------------
NEXT_PUBLIC_APP_NAME=FDC Modular
NEXT_PUBLIC_APP_VERSION=1.0.0

# ----------------------------------------
# Stripe (Phase 47 - Optional: Billing features)
# ----------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID_MONTHLY=price_xxx
# STRIPE_PRICE_ID_HALF_YEARLY=price_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ----------------------------------------
# Optional: Override port for multi-branch dev
# ----------------------------------------
# PORT=3000

# ----------------------------------------
# Development
# ----------------------------------------
NODE_ENV=development

# ----------------------------------------
# Notes
# ----------------------------------------
#
# NEXT_PUBLIC_ prefix:
#   - Available on the client side (browser)
#   - NEVER put secrets behind NEXT_PUBLIC_
#
# SUPABASE_SERVICE_ROLE_KEY:
#   - Server-side only
#   - NEVER expose to the client
#
# TOKEN_ENCRYPTION_KEY:
#   - Used for AES-256-GCM encryption of Google OAuth tokens
#   - Must be a 32-byte base64-encoded key
#
